«IMPORT uml»
«IMPORT JMM»

«EXTENSION java::GeneratorCommons»
«EXTENSION functions::MavenProject»
«EXTENSION functions::MavenDependency»
«EXTENSION functions::SystemProperties»


«DEFINE GenerateProjectPOM FOR MavenProject»
«LET "POM" AS moduleType»
«FILE this.getPOMOutputDirectory() + "pom.xml" basedir -»
<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
«EXPAND maven::POMHelper::POMCommonBegin»

	<properties>
		<!-- UML package which will be the one that is considered during code generation. -->
		<umlPackage>«this.getMavenProjectUMLPackagePath()»</umlPackage>

«IF isMavenProjectGeneratedFromModelTemplate() -»
		<!-- Name of the main file of the UML model -->
		<umlModelFile>«mavenProjectGenerationUMLModelFile("TODO")»</umlModelFile>
«ELSE -»
		<!-- Name of the main file of the UML model -->
		<umlModelFile>«getUMLModelFile()»</umlModelFile>
«ENDIF-»
«IF this.hasOwnUMLModelCoordinates()-»

		«PROTECT CSTART "<!-- " CEND " -->" ID "xmi-properties:"  + this.getProjectID()»
		<!-- 
			Directory on local file system from where XMI files should be read. 
			Property only needs to be set in case that you want read XMI files from local file system
		-->
		<my.xmiDirectory></my.xmiDirectory>
		
		<!--
			Properties are use to specify the Maven artifact from which the XMI files should be read.
			Properties only need to be set in case that you want read XMI files from a Maven artifact.
		-->
		<my.modelArtifactGroupID>«mavenProjectGenerationUMLModelArtifactGroupID("TODO")»</my.modelArtifactGroupID>
		<my.modelArtifactArtifactID>«mavenProjectGenerationUMLModelArtifactArtifactID("TODO")»</my.modelArtifactArtifactID>
		<my.modelArtifactXMIPath>«mavenProjectGenerationUMLModelArtifactXMIPath("xmi")»</my.modelArtifactXMIPath>
		«ENDPROTECT»
«ENDIF-»

«IF isMavenProjectGeneratedFromModelTemplate() && isUMLArtifactGAVDefined()-»
		<!-- Version property for dependency to «mavenProjectGenerationUMLModelArtifactGroupID()»:«mavenProjectGenerationUMLModelArtifactArtifactID()» -->
		<«mavenProjectGenerationUMLModelArtifactArtifactID()».version>«mavenProjectGenerationUMLModelArtifactVersion()»</«mavenProjectGenerationUMLModelArtifactArtifactID()».version>

«ENDIF-»
«FOREACH this.getDependentProjects() AS project-»
		<!-- Version property for dependency to «project.getProjectID()» -->
		<«project.getVersionPropertyName()»>«project.getVersion()»</«project.getVersionPropertyName()»>

«ENDFOREACH-»
«FOREACH this.getMavenDependencies(moduleType).getMavenProject() AS dependentProject-»
		<!-- Version property for dependency to «dependentProject.getProjectID()» -->
		<«dependentProject.getVersionPropertyName()»>«dependentProject.getVersion()»</«dependentProject.getVersionPropertyName()»>

«ENDFOREACH-»
«IF this.isCustomizable() -»
		<!-- Custom section for properties -->
		«PROTECT CSTART "<!-- " CEND " -->" ID "properties:"  + this.getProjectID()»
		<!-- Everything that is within this protection area will remain unchanged by JEAF Generator. -->
		<!-- Add your custom properties here -->
		«ENDPROTECT»
«ENDIF-»
	</properties>


	<!-- "Extend" profiles from parent POM for usages of XMI files from local file system and Maven artifact usage. -->
	<profiles>
		<profile>
			<id>RunCodeGenerationFromXMIFile</id>
			<properties>
				<!-- Read UML model (XMI files) directly from local file system -->
				<xmiDirectory>${my.xmiDirectory}</xmiDirectory>
			</properties>
		</profile>
		<profile>
			<id>RunCodeGenerationFromModelArtifact</id>
			<properties>
				<!-- Read UML model from Maven artifact. -->
				<modelArtifactGroupID>${my.modelArtifactGroupID}</modelArtifactGroupID>
				<modelArtifactArtifactID>${my.modelArtifactArtifactID}</modelArtifactArtifactID>
				<modelArtifactXMIPath>${my.modelArtifactXMIPath}</modelArtifactXMIPath>
			</properties>
		</profile>
		<profile>
			<id>UpdateMavenProjectStructureFromXMIFile</id>
			<properties>
				<!-- Read UML model (XMI files) directly from local file system -->
				<xmiDirectory>${my.xmiDirectory}</xmiDirectory>
			</properties>
		</profile>
		<profile>
			<id>UpdateMavenProjectStructureFromModelArtifact</id>
			<properties>
				<!-- Read UML model from Maven artifact. -->
				<modelArtifactGroupID>${my.modelArtifactGroupID}</modelArtifactGroupID>
				<modelArtifactArtifactID>${my.modelArtifactArtifactID}</modelArtifactArtifactID>
				<modelArtifactXMIPath>${my.modelArtifactXMIPath}</modelArtifactXMIPath>
			</properties>
		</profile>
«IF this.isCustomizable() -»

		<!-- Section for custom profile entries -->
		«PROTECT CSTART "<!-- " CEND " -->" ID "profiles:"  + this.getProjectID()»
		<!-- Everything that is within this protection area will remain unchanged by JEAF Generator. -->
		«ENDPROTECT»
«ENDIF-»
	</profiles>


	<modules>
«FOREACH this.getModuleTypes() AS type -»
		<module>«this.getModuleArtifactId(type)»</module>
«ENDFOREACH -»
	</modules>


	<dependencyManagement>
		<dependencies>
«FOREACH this.getDependentProjects().select(e|e.isArchetypeUMLModelProject() == false) AS project -»
			<dependency>
				<groupId>«project.getGroupId()»</groupId>
				<artifactId>«project.getBOMArtifactId()»</artifactId>
				<version>«project.getVersionPropertyVariable()»</version>
				<type>pom</type>
				<scope>import</scope>
			</dependency>
«ENDFOREACH -»
«FOREACH this.getModuleTypesForBOM() AS module -»
			<dependency>
				<groupId>«this.getGroupId()»</groupId>
				<artifactId>«this.getModuleArtifactId(module)»</artifactId>
				<version>«this.getVersion()»</version>
			</dependency>
«ENDFOREACH -»
«IF this.isCustomizable() -»
			<!-- Section for custom dependency management entries -->
			«PROTECT CSTART "<!-- " CEND " -->" ID "dependencyManagement:"  + this.getProjectID()»
			<!-- Everything that is within this protection area will remain unchanged by JEAF Generator. -->
			«ENDPROTECT»
«ENDIF-»
		</dependencies>
	</dependencyManagement>

«EXPAND maven::POMHelper::GenerateDependenciesSection(moduleType, null, null, null) -»
«IF this.isCustomizable() -»


	<build>
		<plugins>
			<!-- Section for custom plugin entries -->
			«PROTECT CSTART "<!-- " CEND " -->" ID "plugins:"  + this.getProjectID()»
			<!-- Everything that is within this protection area will remain unchanged by JEAF Generator. -->
			«ENDPROTECT»
		</plugins>
	</build>
«ENDIF-»
</project>
«ENDFILE»
«ENDLET»
«ENDDEFINE»
