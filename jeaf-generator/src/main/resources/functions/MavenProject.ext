cached boolean hasDomainProjects(JMM::MavenProject project):
	!project.getDomainProjects().isEmpty;


cached List[JMM::MavenProject] getDomainProjects(JMM::MavenProject project):
	if project.belongsToDomain()
	then project.getDomain().allOwnedElements().typeSelect(JMM::MavenProject).select(e|e.isDomainArchetype())
	else {};


private boolean isDomainArchetype(JMM::MavenProject project):
	switch (project.archetype.name) {
		case "DATA_TYPES": true
		case "SERVICE_MODEL": true
		case "MASTER_DATA": true
		case "EVENTS": true
		case "IMPLEMENTATION": true
		default: false
	};


//
// Archetype operations.
//

cached isArchetypeGeneratorProjectParentPOM(JMM::MavenProject project):
	project.getArchetype() == "GENERATOR_PROJECT_PARENT_POM";

cached isArchetypeDomain(JMM::MavenProject project):
	project.getArchetype() == "DOMAIN";

cached isArchetypeDataTypes(JMM::MavenProject project):
	project.getArchetype() == "DATA_TYPES";

cached isArchetypeServiceModel(JMM::MavenProject project):
	project.getArchetype() == "SERVICE_MODEL";

cached isArchetypeMasterData(JMM::MavenProject project):
	project.getArchetype() == "MASTER_DATA";

cached isArchetypeEvents(JMM::MavenProject project):
	project.getArchetype() == "EVENTS";

cached isArchetypeImplementation(JMM::MavenProject project):
	project.getArchetype() == "IMPLEMENTATION";

cached isArchetypeUMLModelProject(JMM::MavenProject project):
	project.getArchetype() == "UML_MODEL_PROJECT";

cached isArchetypeExternalProject(JMM::MavenProject project):
	project.getArchetype() == "EXTERNAL_PROJECT";

cached isArchetypeCustom(JMM::MavenProject project):
	project.getArchetype() == "CUSTOM";
	
cached requiresProjectPOM(JMM::MavenProject project):
	if project.isArchetypeGeneratorProjectParentPOM() || project.isArchetypeExternalProject()
	then false
	else true;

cached List[String] getIntegrationTestModuleDependencies(JMM::MavenProject project):
	if project.isArchetypeServiceModel()
	then {"REST_CLIENT_STARTER", "REST_CONTROLLER_STARTER"}
	else {"JAVA_STARTER"};
	
cached List[String] getIntegrationTestSpringDependencies(JMM::MavenProject project):
	if project.isArchetypeServiceModel()
	then {"org.springframework.boot:spring-boot-starter-web", "org.springframework.boot:spring-boot-starter-webflux"}
	else null;

cached String getPOMOutputDirectory(JMM::MavenProject project):
	if initialProjectGeneration() == false
	then ""
	else "temp/" + project.getArtifactId() + "/";

