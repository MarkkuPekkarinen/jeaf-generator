private cached String toMavenId(String input):
	input.toLowerCase().replaceAll(" ", "-");

//
// Maven Dependencies
//
cached boolean hasParentPOM(JMM::MavenProject project):
	project.getParentPOM() != null;
	
cached boolean hasDefaultParentPOM(JMM::MavenProject project):
	getMavenProjectDefaultParentGroupId().length > 0;

cached JMM::MavenProject getParentPOM(JMM::MavenProject project):
	project.clientDependency.typeSelect(JMM::MavenParentPOM).first().supplier.typeSelect(JMM::MavenProject).first();
	
cached boolean hasOwnUMLModelCoordinates(JMM::MavenProject project):
	if project.getUMLCoordinatesSource() == "NONE"
	then false
	else
		if project.getUMLCoordinatesSource() == "USE_OWN"
		then true
		else
			if project.getUMLCoordinatesSource() == "USE_FROM_PARENT_POM"
			then false
			else
				if project.getUMLCoordinatesSource() == "USE_PARENT_OR_OWN" && project.hasParentPOM() && project.getParentPOM().hasUMLModelCoordinates()
				then false
				else 
					true;
	
cached boolean hasUMLModelCoordinates(JMM::MavenProject project):
	if project.hasOwnUMLModelCoordinates()
	then true
	else
		if project.hasParentPOM() && project.getParentPOM().hasUMLModelCoordinates()
		then true
		else false;

cached String getUMLCoordinatesSource(JMM::MavenProject project):
	if project.modelCoordinatesSource.name == "USE_DEFAULT"
	then defaultUMLCoordinatesSource()
	else project.modelCoordinatesSource.name;

cached List[JMM::MavenProject] getDependentProjects(JMM::MavenProject project):
	project.getMavenProjectDependencies().supplier.typeSelect(JMM::MavenProject);
	
cached List[JMM::MavenProjectDependency] getMavenDependenciesForModule(JMM::MavenProject project, String moduleDependencyType):
	project.getMavenProjectDependencies().select(e|e.moduleDependencyTypes.toString().contains(moduleDependencyType));
	
cached List[JMM::MavenProjectDependency] getMavenProjectDependencies(JMM::MavenProject project):
	project.clientDependency.typeSelect(JMM::MavenProjectDependency);

cached List[JMM::MavenDependency] getMavenDependencies(JMM::MavenProject project, String sourceModuleType):
	project.clientDependency.typeSelect(JMM::MavenDependency).select(e| e.sourceModuleTypes.toString().contains(sourceModuleType));
	
cached JMM::MavenProject getMavenProject(JMM::MavenDependency dependency):
	dependency.supplier.typeSelect(JMM::MavenProject).first();

cached JMM::MavenProject getMavenProject(JMM::MavenProjectDependency dependency):
	dependency.supplier.typeSelect(JMM::MavenProject).first();

cached boolean hasTargetModuleTypeMapping(String sourceModule, String moduleDependencyType):
	JAVA com.anaptecs.jeaf.fwk.generator.util.maven.ModuleType.hasTargetModuleTypeMapping(java.lang.String, java.lang.String);

cached String getTargetModuleType(String sourceModule, String moduleDependencyType):
