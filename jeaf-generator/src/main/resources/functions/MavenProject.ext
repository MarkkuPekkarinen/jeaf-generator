List[String] getTechnicalDependenciesForJavaModule():
	if addRequiredTechnicalDepdendencies() == false
	then {}
	else 
		if generateJacksonAnnotations() && isJackson3Enabled()
		then {"jakarta.annotation:jakarta.annotation-api", "jakarta.validation:jakarta.validation-api", "tools.jackson.core:jackson-databind"}
		else {"jakarta.annotation:jakarta.annotation-api", "jakarta.validation:jakarta.validation-api"};


List[String] getTechnicalDependenciesForServiceModule(JMM::MavenProject project):
	if addRequiredTechnicalDepdendencies() && (generateReactiveServiceInterfaces() || initialProjectGeneration() || project.generateReactiveServices()) 
	then {"io.projectreactor:reactor-core"}
	else {};
