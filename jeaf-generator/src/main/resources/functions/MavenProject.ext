cached boolean isMavenProject(uml::Element element) :
	element.isStereotypeApplied("MavenProject");

cached JMM::MavenProject asMavenProject(uml::Element element):
	(JMM::MavenProject) element;

cached String getMavenProjectName(JMM::MavenProject project):
	if isMavenProjectGeneratedFromModelTemplate()
	then getProjectNamePattern()
	else
		if project.name.trim().length > 0
		then project.name.trim().convertPatternToEffectiveValue(project)
		else getProjectNamePattern().convertPatternToEffectiveValue(project);	

cached String getMavenProjectDescription(JMM::MavenProject project):
	if project.getMarkdownComment().length > 0
	then project.getMarkdownComment().convertPatternToEffectiveValue(project)
	else getProjectDescriptionPattern().convertPatternToEffectiveValue(project);

cached String getMavenProjectURL(JMM::MavenProject project):
	if project.projectURL.trim().length > 0
	then project.projectURL.trim().convertPatternToEffectiveValue(project)
	else getProjectURLPattern().convertPatternToEffectiveValue(project);

cached String getGroupId(JMM::MavenProject project):
	if project.groupId.trim().length > 0
	then project.groupId.trim().convertPatternToEffectiveValue(project)
	else getGroupIdPattern().convertPatternToEffectiveValue(project);

cached String getArtifactId(JMM::MavenProject project):
	if project.artifactId.trim().length > 0
	then project.artifactId.trim().convertPatternToEffectiveValue(project)
	else getArtifactIdPattern().convertPatternToEffectiveValue(project);

cached String getProjectID(JMM::MavenProject project):
	project.getGroupId() + ":" + project.getArtifactId();
	
cached String getModuleID(JMM::MavenProject project, String moduleType):
	project.getGroupId() + ":" + project.getModuleArtifactId(moduleType);

cached String getVersion(JMM::MavenProject project):
	if project.getProjectID().javaGetArtifactVersion().length > 0
	then project.getProjectID().javaGetArtifactVersion()
	else getMavenArtifactDefaultVersion();

cached String getSCMUrl(JMM::MavenProject project):
	if project.scmPath.trim().length > 0
	then project.scmPath.trim().convertPatternToEffectiveValue(project)
	else getSCMPathPattern().convertPatternToEffectiveValue(project);
	
cached String getSCMConnection(JMM::MavenProject project):
	javaGetSCMConnection(project.scmType.name, project.getSCMUrl());

cached String getVersionPropertyName(JMM::MavenProject project):
	getVersionPropertyNamePattern().convertPatternToEffectiveValue(project);
	
cached String getVersionPropertyVariable(JMM::MavenProject project):
	"${" + project.getVersionPropertyName() + "}";

cached boolean isCustomizable(JMM::MavenProject project):
	project.customizable;

cached boolean generateSyncServices(JMM::MavenProject project):
	if project.isArchetypeServiceModel() && (project.serviceTypes.isEmpty ||  project.serviceTypes.select(e|e.toString() == "SYNCHRONOUS").size > 0)
	then true
	else false;

cached boolean generateReactiveServices(JMM::MavenProject project):
	if project.isArchetypeServiceModel() && (project.serviceTypes.isEmpty ||  project.serviceTypes.select(e|e.toString() == "REACTIVE").size > 0)
	then true
	else false;

