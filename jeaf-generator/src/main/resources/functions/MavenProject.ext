private String convertPatternToEffectiveValue(String pattern, JMM::MavenProject project):
	if pattern.length == 0
	then ""
	else 
		pattern
			.inlineProjectNameMaven(project)
			.inlineMavenProjectPackageName(project)
			.inlineMavenProjectPackageNameFQN(project)
			.inlineArchetype(project)
			.inlineArchetypeName(project)
			.inlineArchetypeJavaSuffix(project)
			.inlineArchetypeMavenSuffix(project)
			.inlineArtifactId(project)
			.inlineGroupId(project)
			.inlineDomainPackageName(project)
			.inlineDomainPackageFQN(project)
			.inlineDomainNameForProject(project)
			.inlineDomainNameJavaForProject(project)
			.inlineDomainGroupIdForProject(project)
	;
	
private String inlineProjectNameMaven(String pattern, JMM::MavenProject project):
	if pattern.contains("$[PROJECT_NAME_MAVEN]")
	then pattern.replaceAll("\\$\\[PROJECT_NAME_MAVEN\\]", project.getProjectNameMaven())
	else pattern;

private String inlineMavenProjectPackageName(String pattern, JMM::MavenProject project):
	if pattern.contains("$[PROJECT_PACKAGE_NAME]")
	then pattern.replaceAll("\\$\\[PROJECT_PACKAGE_NAME\\]", project.getMavenProjectPackageName())
	else pattern;

