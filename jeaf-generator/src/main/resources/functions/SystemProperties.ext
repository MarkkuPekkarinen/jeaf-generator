
String getSystemProperty(String propertyName):
   JAVA java.lang.System.getProperty(java.lang.String);


String getSystemProperty(String propertyName, String defaultValue):
   JAVA java.lang.System.getProperty(java.lang.String, java.lang.String);


boolean getBooleanSystemProperty(String propertyName, boolean defaultValue):
	if getSystemProperty(propertyName, defaultValue.toString()) == "true"
	then true
	else false;


List[String] getSystemPropertyValues(String propertyName):
	JAVA com.anaptecs.jeaf.fwk.generator.util.SystemProperties.getPropertiesList(java.lang.String);    

List[String] getSystemPropertyValues(String propertyName, String defaultValue):
	if propertyName.getSystemPropertyValues().isEmpty
	then {defaultValue}.toList()
	else propertyName.getSystemPropertyValues();


