<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">

	<modelVersion>4.0.0</modelVersion>


	<groupId>com.anaptecs.jeaf.generator</groupId>
	<artifactId>magic-project-parent</artifactId>
	<version>47.1.1</version>

	<packaging>pom</packaging>
	<name>Customer Parent POM</name>


	<scm>
		<connection>scm:git:https://github.com/anaptecs/customer-parent-pom>.git</connection>
		<developerConnection>scm:git:https://github.com/anaptecs/customer-parent-pom>.git</developerConnection>
		<url>https://github.com/anaptecs/customer-parent-pom></url>
		<tag>HEAD</tag>
	</scm>


	<properties>
		<!-- UML package which will be the one that is considered during code generation. -->
		<umlPackage>com.anaptecs.maven</umlPackage>

		<!-- Name of the main file of the UML model -->
		<umlModelFile>JEAF_Test.uml</umlModelFile>

		<!-- PROTECTED REGION ID(xmi-properties:com.anaptecs.jeaf.generator:magic-project-parent) ENABLED START -->
		<!-- 
			Directory on local file system from where XMI files should be read. 
			Property only needs to be set in case that you want read XMI files from local file system
		-->
		<my.xmiDirectory></my.xmiDirectory>
		
		<!--
			Properties are use to specify the Maven artifact from which the XMI files should be read.
			Properties only need to be set in case that you want read XMI files from a Maven artifact.
		-->
		<my.modelArtifactGroupID>TODO</my.modelArtifactGroupID>
		<my.modelArtifactArtifactID>TODO</my.modelArtifactArtifactID>
		<my.modelArtifactXMIPath>xmi</my.modelArtifactXMIPath>
		<!-- PROTECTED REGION END -->

	</properties>


	<!-- "Extend" profiles from parent POM for usages of XMI files from local file system and Maven artifact usage. -->
	<profiles>
		<profile>
			<id>RunCodeGenerationFromXMIFile</id>
			<properties>
				<!-- Read UML model (XMI files) directly from local file system -->
				<xmiDirectory>${my.xmiDirectory}</xmiDirectory>
			</properties>
		</profile>
		<profile>
			<id>RunCodeGenerationFromModelArtifact</id>
			<properties>
				<!-- Read UML model from Maven artifact. -->
				<modelArtifactGroupID>${my.modelArtifactGroupID}</modelArtifactGroupID>
				<modelArtifactArtifactID>${my.modelArtifactArtifactID}</modelArtifactArtifactID>
				<modelArtifactXMIPath>${my.modelArtifactXMIPath}</modelArtifactXMIPath>
			</properties>
		</profile>
		<profile>
			<id>UpdateMavenProjectStructureFromXMIFile</id>
			<properties>
				<!-- Read UML model (XMI files) directly from local file system -->
				<xmiDirectory>${my.xmiDirectory}</xmiDirectory>
			</properties>
		</profile>
		<profile>
			<id>UpdateMavenProjectStructureFromModelArtifact</id>
			<properties>
				<!-- Read UML model from Maven artifact. -->
				<modelArtifactGroupID>${my.modelArtifactGroupID}</modelArtifactGroupID>
				<modelArtifactArtifactID>${my.modelArtifactArtifactID}</modelArtifactArtifactID>
				<modelArtifactXMIPath>${my.modelArtifactXMIPath}</modelArtifactXMIPath>
			</properties>
		</profile>
	</profiles>


	<modules>
	</modules>


	<dependencyManagement>
		<dependencies>
		</dependencies>
	</dependencyManagement>


	<dependencies>
	</dependencies>
</project>
